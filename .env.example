VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_FUNCTION_DOMAIN=pxlxdlrjmrkxyygdhvku.functions.supabase.co
VITE_SITE_URL=http://localhost:5173
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Note: ZEPTO_TOKEN is required as a Supabase Edge Function secret, not a local environment variable
# Set this in your Supabase project dashboard under Edge Functions > send-email > Environment Variables

# ─────────────────────────────────────────────────────────────────────────────
# Residential-rental monetization (Phase A–G).
# These are Edge Function SECRETS, not VITE_ vars. Set them in:
#   Supabase dashboard → Project Settings → Edge Functions → Secrets
# (or via: supabase secrets set KEY=value)
#
# Stripe API
#   STRIPE_API_KEY              # already used by existing functions
#   STRIPE_WEBHOOK_SECRET       # already used by existing functions
#
# Listing subscriptions (Agent / VIP) and Concierge add-on price IDs.
# Create three recurring monthly prices in Stripe and paste the IDs here:
#   STRIPE_AGENT_PRICE_ID            # $50 / month
#   STRIPE_VIP_PRICE_ID              # $100 / month
#   STRIPE_ADDON_CONCIERGE_PRICE_ID  # $50 / month (only chargeable bundled with Agent/VIP)
#
# NOTE — Individual listing payments ($25 first month, $15 renewal, multi-month
# packages) do NOT need pre-created Stripe Price objects. The checkout uses
# ad-hoc `price_data` and reads dollar amounts from
#   src/types/monetization.ts → INDIVIDUAL_LISTING_PACKAGES
#   supabase/functions/_shared/stripe-prices.ts → INDIVIDUAL_LISTING_PACKAGES
# (the two are kept in sync manually). To change pricing, edit those two files.
#
# Twilio (already used by existing SMS flows; reused by send-paid-listing-reminders).
#   TWILIO_ACCOUNT_SID
#   TWILIO_AUTH_TOKEN
#   TWILIO_PHONE_NUMBER
#
# Public site URL (used in SMS body checkout links).
#   PUBLIC_SITE_URL=https://hadirot.com
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Remaining Edge Function secrets (Supabase dashboard → Project Settings →
# Edge Functions → Secrets, or `supabase secrets set KEY=value`). Grouped by
# which function(s) actually call Deno.env.get(...) for each key.
#
# Core (used by nearly every function):
#   SUPABASE_URL                # project URL, service-role client
#   SUPABASE_ANON_KEY            # anon client, used to verify caller JWTs
#   SUPABASE_SERVICE_ROLE_KEY    # service-role client for admin operations
#   SITE_URL / PUBLIC_SITE_URL   # base URL used in email/SMS links
#     (approve-listing, pay-listing-link, send-email, send-enhanced-digest,
#      send-listing-contact-sms, send-listing-email-manual,
#      send-password-reset, send-daily-admin-digest, stripe-webhook)
#
# Cron authentication — shared by supabase/functions/_shared/requireCronSecret.ts,
# used by every function invoked on a schedule via pg_cron:
#   CRON_SECRET
#     (delete-old-listings, inactivate-old-listings, send-deactivation-emails,
#      cleanup-expired-renewals, send-renewal-reminders,
#      send-weekly-performance-reports, send-paid-listing-reminders,
#      update-neighborhood-polygons)
#
# ZeptoMail (shared by supabase/functions/_shared/zepto.ts and every function
# that sends transactional email):
#   ZEPTO_TOKEN
#   ZEPTO_FROM_ADDRESS
#   ZEPTO_FROM_NAME
#   ZEPTO_REPLY_TO
#     (send-contact-message, send-daily-admin-digest, send-email,
#      send-listing-email-manual, send-password-reset, stripe-webhook)
#
# send-contact-message:
#   CONTACT_RECIPIENT           # inbox that receives the "Contact Us" form submissions
#
# send-email:
#   EMAIL_PROVIDER               # selects the outbound provider (zepto, etc.)
#   EMAIL_ALLOWLIST_DOMAIN        # restricts recipient domain in non-prod environments
#
# geocode-cross-streets:
#   GOOGLE_MAPS_API_KEY           # server-side key, distinct from VITE_GOOGLE_MAPS_API_KEY above
#
# generate-listing-image / send-listing-email-manual (listing image cards):
#   HTMLCSSTOIMAGE_API_KEY
#   HTMLCSSTOIMAGE_USER_ID
#
# redirect-short-url:
#   ALLOWED_REDIRECT_HOSTS        # comma-separated allowlist for short-link redirect targets
#
# track (analytics ingest):
#   DEBUG_ANALYTICS               # verbose logging toggle, not for production
#
# Error reporting (supabase/functions/_shared/reportError.ts), wired into
# delete-user, cleanup-expired-renewals, inactivate-old-listings,
# delete-old-listings, cascade-deactivate-subscription, approve-listing,
# extend-paid-listing, send-deactivation-emails:
#   SENTRY_DSN                    # edge-function DSN (can be the same project as the client DSN)
#   SENTRY_ENVIRONMENT            # optional, defaults to "production" if unset
#
# Build-time only (not an Edge Function secret — set in the frontend deploy
# environment for @sentry/vite-plugin, see vite.config.ts):
#   SENTRY_AUTH_TOKEN             # Sentry auth token with project:releases scope
#   SENTRY_ORG
#   SENTRY_PROJECT
# ─────────────────────────────────────────────────────────────────────────────
